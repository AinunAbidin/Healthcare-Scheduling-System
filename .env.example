NODE_ENV=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=healthcare
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_ENABLED=true
CACHE_TTL_SECONDS=60

AUTH_SERVICE_PORT=3001
SCHEDULE_SERVICE_PORT=3002

AUTH_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/healthcare?schema=auth
SCHEDULE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/healthcare?schema=schedule

JWT_SECRET=change-this-secret-with-at-least-16-characters
JWT_EXPIRES_IN=1h

AUTH_GRAPHQL_PLAYGROUND=true
SCHEDULE_GRAPHQL_PLAYGROUND=true

AUTH_SERVICE_GRAPHQL_URL=http://auth-service:3001/graphql
AUTH_SERVICE_TIMEOUT_MS=5000

EMAIL_FROM=no-reply@healthcare.local
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
